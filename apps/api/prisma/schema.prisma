generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemType {
  movie
  series
  episode
}

enum ListKind {
  watchlist
  custom
}

enum ListItemType {
  movie
  series
}

enum WatchEventType {
  movie
  episode
}

enum MetadataType {
  movie
  series
}

enum ScrobbleStatus {
  playing
  paused
  stopped
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  createdAt DateTime @default(now()) @db.Timestamp(6)
}

model Item {
  id           String   @id @default(uuid()) @db.Uuid
  type         ItemType
  imdbId       String
  parentImdbId String?
  season       Int?
  episode      Int?
  title        String?
  createdAt    DateTime @default(now()) @db.Timestamp(6)

  @@index([imdbId])
  @@unique([type, imdbId])
}

model List {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  kind      ListKind
  createdAt DateTime   @default(now()) @db.Timestamp(6)
  items     ListItem[]
}

model ListItem {
  listId  String       @db.Uuid
  type    ListItemType
  imdbId  String
  addedAt DateTime     @default(now()) @db.Timestamp(6)

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, type, imdbId])
  @@index([listId])
}

model WatchEvent {
  id           String         @id @default(uuid()) @db.Uuid
  type         WatchEventType
  imdbId       String
  seriesImdbId String?
  season       Int?
  episode      Int?
  watchedAt    DateTime       @db.Timestamptz(6)
  plays        Int            @default(1)
}

model SeriesProgress {
  seriesImdbId String   @id
  lastSeason   Int
  lastEpisode  Int
  lastWatchedAt DateTime @db.Timestamptz(6)
  updatedAt    DateTime @db.Timestamptz(6)

  @@index([lastWatchedAt], name: "idx_seriesprogress_lastWatchedAt")
}

model KV {
  key       String   @id
  value     String
  updatedAt DateTime @db.Timestamp(6)
}

model TraktToken {
  id           String   @id @default("default")
  accessToken  String
  refreshToken String
  expiresAt    DateTime @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)
}

model ScrobbleSession {
  id           String          @id @default(uuid()) @db.Uuid
  type         WatchEventType
  imdbId       String
  seriesImdbId String?
  season       Int?
  episode      Int?
  status       ScrobbleStatus  @default(playing)
  progress     Float           @default(0) // 0-100 percentage
  startedAt    DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @db.Timestamptz(6)

  @@index([imdbId, season, episode, status])
}

model Metadata {
  imdbId        String
  type          MetadataType
  tmdbId        Int?
  name          String
  year          Int?
  poster        String?
  background    String?
  description   String?      @db.Text
  genres        String[]     @default([])
  rating        Float?
  voteCount     Int?
  totalSeasons  Int?
  totalEpisodes Int?
  updatedAt     DateTime     @updatedAt @db.Timestamptz(6)

  @@unique([imdbId, type])
}
