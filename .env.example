# Local development defaults only. Do not use in production.

# Postgres (required for docker-compose)
POSTGRES_DB=cataloggy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API auth (required)
API_TOKEN=dev-token

# API runtime (optional; docker-compose sets internal defaults)
DATABASE_URL=
PORT=
TRAKT_POLL_INTERVAL_SEC=300

# Addon runtime (optional; docker-compose sets internal defaults)
CATALOGGY_API_BASE=
CATALOGGY_API_TOKEN=
ADDON_PUBLIC_BASE=

# Trakt integration (optional; required only for /trakt/import and /trakt/poll)
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_ACCESS_TOKEN=
TRAKT_REFRESH_TOKEN=

# TMDB integration (optional; required for /search and /meta/:type/:imdbId)
TMDB_API_KEY=
